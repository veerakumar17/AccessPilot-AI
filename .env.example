# ==============================================================================
# AccessPilot AI — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ==============================================================================

# --- Application -----------------------------------------------------------
APP_NAME=AccessPilot AI
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-secret-key

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/accesspilot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- JWT / Auth ------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider ----------------------------------------------------------
# AccessPilot AI uses Groq for AI-powered accessibility analysis
# Get your free API key at: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_MAX_RETRIES=3
GROQ_REQUEST_TIMEOUT=60

# --- Crawler ---------------------------------------------------------------
CRAWLER_MAX_PAGES=20
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_HEADLESS=true

# --- CORS ------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO

# --- Frontend (create frontend/.env from these) ----------------------------
# VITE_API_BASE_URL=http://localhost:8000