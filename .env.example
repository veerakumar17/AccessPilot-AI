# ==============================================================================
# AccessPilot AI — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ==============================================================================

# --- Application -----------------------------------------------------------
APP_NAME=AccessPilot AI
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-secret-key

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/accesspilot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- JWT / Auth ------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider ----------------------------------------------------------
# Supported values: "ollama", "openai", "gemini", "groq"
LLM_PROVIDER=ollama

# -- OpenAI (used when LLM_PROVIDER=openai)
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048
OPENAI_MAX_RETRIES=3
OPENAI_REQUEST_TIMEOUT=60

# -- Ollama (used when LLM_PROVIDER=ollama)
# Download: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_REQUEST_TIMEOUT=120

# -- Gemini (used when LLM_PROVIDER=gemini) — FREE tier
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=2048

# -- Groq (used when LLM_PROVIDER=groq) — FREE tier, fast inference
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_MAX_RETRIES=3
GROQ_REQUEST_TIMEOUT=60

# --- Crawler ---------------------------------------------------------------
CRAWLER_MAX_PAGES=20
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_HEADLESS=true

# --- CORS ------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO

# --- Frontend (create frontend/.env from these) ----------------------------
# VITE_API_BASE_URL=http://localhost:8000